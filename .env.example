# Example configuration file for LLM providers
# Copy this to .env and fill in your actual API keys

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic Configuration
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Ollama Configuration (for local installation)
# Ollama doesn't require an API key, just make sure it's running locally
# Default host is http://localhost:11434
